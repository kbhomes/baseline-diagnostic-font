| {{ pair.ids | join(' + ') }} | {% if pair.layout %}`{{ pair.layout.char }}`{% endif %} | {% if pair.layout %}{{ pair.layout.codepoint }}{% endif %} | {% if pair.labeled %}`{{ pair.labeled.char }}`{% endif %} | {% if pair.labeled %}{{ pair.labeled.codepoint }}{% endif %} |
{% endfor %}

